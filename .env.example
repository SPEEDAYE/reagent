LLM_PROVIDER=openai
LLM_MODEL=gpt-5.1
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT=180
CREW_ATTEMPT_TIMEOUT_SECONDS=600

# Zero-setup local default. The database file is created automatically.
DATABASE_TYPE=sqlite
SQLITE_PATH=./data/reagent.db

# Optional production MongoDB mode:
# DATABASE_TYPE=mongodb
MONGODB_URI=mongodb://localhost:27017
DB_NAME=reagent

ENABLE_WEBSITE_SEARCH_TOOL=0

# Authentication migration
# Production: enable AUTH_REQUIRED and configure exactly one trusted identity
# source: a shared token secret, or headers injected by your API gateway.
AUTH_REQUIRED=0
AUTH_TOKEN_SECRET=
AUTH_TOKEN_ALGORITHM=HS256
AUTH_TRUST_PROXY_HEADERS=0
AUTH_PROXY_SHARED_SECRET=
AUTH_PROXY_SECRET_HEADER=X-Proxy-Secret
AUTH_USER_HEADER=X-User-Code
AUTH_USERNAME_HEADER=X-Username
AUTH_ROLES_HEADER=X-User-Roles

# Persisted SSE replay window
EVENT_RETENTION_DAYS=7

# Process-isolated pipeline concurrency
PIPELINE_MAX_WORKERS=2
PIPELINE_MAX_ACTIVE_PER_USER=2
